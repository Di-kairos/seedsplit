usage() { t usage; }

cmd_version() { echo "seedsplit $VERSION"; }

# === Shamir Secret Sharing над GF(256) (pack 2) ===
# Поле GF(2^8), редуцирующий многочлен 0x11b (как в AES). Сложение = XOR.
# Умножение — через таблицы log/antilog от генератора 0x03 (примитивный элемент поля).
# Деление/инверсия — через те же таблицы. Все операции — над байтами секрета.

# sha256 → hex (портативно: macOS shasum / Linux sha256sum). Для контрольных сумм.
_sha256_hex() {
  if command -v shasum >/dev/null 2>&1; then shasum -a 256 | cut -d' ' -f1
  else sha256sum | cut -d' ' -f1; fi
}
# bytes(stdin) → hex без пробелов; hex(arg) → raw bytes(stdout). Без xxd (нет на части систем).
_to_hex() { od -An -v -tx1 | tr -d ' \n'; }
_from_hex() { local h="$1" i; for ((i=0; i<${#h}; i+=2)); do printf '%b' "\\x${h:i:2}"; done; }

# Таблицы GF(256): GF_EXP[i]=g^i (g=3), GF_LOG[v]=i. Генерируются один раз.
_gf_init() {
  local x=1 i tt
  GF_EXP=(); GF_LOG=()
  for ((i=0; i<255; i++)); do
    GF_EXP[i]=$x
    GF_LOG[x]=$i
    tt=$(( (x<<1) & 0xff ))                 # xtime(x) = x*2 в GF
    if (( x & 0x80 )); then tt=$(( tt ^ 0x1b )); fi
    x=$(( tt ^ x ))                          # x*3 = xtime(x) XOR x
  done
}

cmd_split() {
  require_macos
  local n=3 t=2 file=""
  while (( $# )); do
    case "$1" in
      -n|--shares)    n="${2:?}"; shift 2 ;;
      -t|--threshold) t="${2:?}"; shift 2 ;;
      --file)         file="${2:?}"; shift 2 ;;
      *) err "split: неизвестный аргумент: $1"; exit 1 ;;
    esac
  done

  # Секрет — из stdin или --file, в hex. Никогда из argv (виден в `ps`).
  local secret_hex
  if [[ -n "$file" ]]; then
    [[ -r "$file" ]] || { err "split: файл недоступен: $file"; exit 1; }
    secret_hex="$(_to_hex < "$file")"
  else
    secret_hex="$(_to_hex)"
  fi
  [[ -n "$secret_hex" ]] || { err "split: пустой секрет (подай через stdin или --file)"; exit 1; }

  [[ "$n" =~ ^[0-9]+$ && "$t" =~ ^[0-9]+$ ]] || { err "split: -n/-t должны быть числами"; exit 1; }
  (( t >= 2 )) || { err "split: порог -t должен быть ≥2 (иначе доля = весь секрет)"; exit 1; }
  (( n >= t )) || { err "split: число долей -n ($n) должно быть ≥ порога -t ($t)"; exit 1; }
  (( n <= 255 )) || { err "split: -n не может превышать 255 (точки оценки GF(256))"; exit 1; }

  local L=$(( ${#secret_hex} / 2 ))
  (( L <= 65535 )) || { err "split: секрет слишком большой (>65535 байт)"; exit 1; }

  # Обёртка целостности: 0x55 | len(2B BE) | secret | crc(2B = первые 2 байта sha256 предыдущего).
  # Даёт combine возможность вернуть ЛИБО точный секрет, ЛИБО честный отказ (порча/чужой набор).
  local hi=$(( L >> 8 )) lo=$(( L & 0xff )) core_hex crc_hex
  printf -v core_hex '55%02x%02x%s' "$hi" "$lo" "$secret_hex"
  crc_hex="$(_from_hex "$core_hex" | _sha256_hex)"; crc_hex="${crc_hex:0:4}"
  local payload_hex="${core_hex}${crc_hex}" PL
  PL=$(( ${#payload_hex} / 2 ))

  local -a P=(); local k
  for ((k=0; k<PL; k++)); do P[k]=$(( 16#${payload_hex:k*2:2} )); done

  _gf_init

  # (t-1) случайных байт на каждый байт payload — старшие коэффициенты многочленов.
  local need=$(( (t-1) * PL )) rand_hex
  rand_hex="$(head -c "$need" /dev/urandom | _to_hex)"
  [[ ${#rand_hex} -eq $((need*2)) ]] || { err "split: мало энтропии из /dev/urandom"; exit 1; }

  local -a Y=(); local x j ri=0 y hb
  for ((x=1; x<=n; x++)); do Y[x]=""; done
  for ((k=0; k<PL; k++)); do
    # Многочлен байта k: c0=P[k] (секрет), c1..c_{t-1} = случайные. Оцениваем в x=1..n (Горнер).
    local -a C=(); C[0]=${P[k]}
    for ((j=1; j<t; j++)); do C[j]=$(( 16#${rand_hex:ri*2:2} )); ri=$((ri+1)); done
    for ((x=1; x<=n; x++)); do
      y=${C[t-1]}
      for ((j=t-2; j>=0; j--)); do
        if (( y != 0 )); then y=${GF_EXP[$(( (GF_LOG[y]+GF_LOG[x]) % 255 ))]}; fi
        y=$(( y ^ C[j] ))
      done
      printf -v hb '%02x' "$y"; Y[x]+="$hb"
    done
  done

  # Доля: SSS1-<T>-<x>-<hexY>-<chk4>. chk ловит опечатку в этой конкретной доле.
  for ((x=1; x<=n; x++)); do
    local body="SSS1-${t}-${x}-${Y[x]}" chk
    chk="$(printf '%s' "$body" | _sha256_hex)"; chk="${chk:0:4}"
    printf '%s-%s\n' "$body" "$chk"
  done
}

cmd_combine() {
  require_macos
  local raw
  if (( $# )); then raw="$(cat "$@")"; else raw="$(cat)"; fi

  _gf_init
  local -a XS=() YS=()
  local line ylen="" t_decl="" cnt=0
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    if [[ ! "$line" =~ ^SSS1-([0-9]+)-([0-9]+)-([0-9a-f]+)-([0-9a-f]{4})$ ]]; then
      err "combine: строка не похожа на долю SSS1: $line"; exit 1
    fi
    local T="${BASH_REMATCH[1]}" x="${BASH_REMATCH[2]}" yh="${BASH_REMATCH[3]}" chk="${BASH_REMATCH[4]}"
    local body="SSS1-${T}-${x}-${yh}" want
    want="$(printf '%s' "$body" | _sha256_hex)"; want="${want:0:4}"
    [[ "$chk" == "$want" ]] || { err "combine: доля повреждена (контрольная сумма не сошлась): x=$x"; exit 1; }
    (( x >= 1 && x <= 255 )) || { err "combine: недопустимый номер доли x=$x"; exit 1; }
    local d; for d in "${XS[@]:-}"; do [[ "$d" == "$x" ]] && { err "combine: повторяющаяся доля x=$x"; exit 1; }; done
    [[ -z "$ylen" ]] && ylen="${#yh}"
    [[ "${#yh}" -eq "$ylen" ]] || { err "combine: доли разной длины — набор несовместим"; exit 1; }
    t_decl="$T"; XS+=("$x"); YS+=("$yh"); cnt=$((cnt+1))
  done <<< "$raw"

  (( cnt >= 1 )) || { err "combine: не подано ни одной доли"; exit 1; }
  if [[ -n "$t_decl" ]] && (( cnt < t_decl )); then
    err "combine: нужно минимум $t_decl долей, подано $cnt"; exit 1
  fi

  # Веса Лагранжа в нуле (одинаковы для всех байтов): w_i = prod_{j!=i} x_j * inv(x_i XOR x_j).
  local m=$cnt i j
  local -a W=()
  for ((i=0; i<m; i++)); do
    local num=1 xi="${XS[i]}"
    for ((j=0; j<m; j++)); do
      (( j == i )) && continue
      local xj="${XS[j]}"; local den=$(( xi ^ xj ))
      (( den != 0 )) || { err "combine: совпадающие точки долей"; exit 1; }
      num=${GF_EXP[$(( (GF_LOG[num]+GF_LOG[xj]) % 255 ))]}                 # num *= x_j
      num=${GF_EXP[$(( (GF_LOG[num]+(255-GF_LOG[den])%255) % 255 ))]}      # num *= inv(den)
    done
    W[i]=$num
  done

  # Восстановление каждого байта payload: acc = XOR_i ( y_i[p] * w_i ).
  local PL=$(( ylen / 2 )) p payload_hex="" acc yb term hb
  for ((p=0; p<PL; p++)); do
    acc=0
    for ((i=0; i<m; i++)); do
      yb=$(( 16#${YS[i]:p*2:2} ))
      if (( yb != 0 )); then
        term=${GF_EXP[$(( (GF_LOG[yb]+GF_LOG[W[i]]) % 255 ))]}
        acc=$(( acc ^ term ))
      fi
    done
    printf -v hb '%02x' "$acc"; payload_hex+="$hb"
  done

  # Проверка обёртки: либо точный секрет, либо честный отказ.
  local bad="combine: набор не образует валидный секрет (доли повреждены или от разных секретов)"
  (( PL >= 6 )) || { err "$bad"; exit 1; }
  (( 16#${payload_hex:0:2} == 0x55 )) || { err "$bad"; exit 1; }
  local len=$(( 16#${payload_hex:2:4} ))
  (( PL == len + 5 )) || { err "$bad"; exit 1; }
  local core_hex="${payload_hex:0:$(( (len+3)*2 ))}" crc_have="${payload_hex: -4}" crc_want
  crc_want="$(_from_hex "$core_hex" | _sha256_hex)"; crc_want="${crc_want:0:4}"
  [[ "$crc_have" == "$crc_want" ]] || { err "$bad"; exit 1; }

  _from_hex "${payload_hex:6:$(( len*2 ))}"
}

main() {
  local cmd="${1:-}"
  if [[ -z "$cmd" ]]; then usage; exit 1; fi
  shift || true
  case "$cmd" in
    version)        cmd_version "$@" ;;
    help|--help|-h) usage ;;
    split)          cmd_split "$@" ;;
    combine)        cmd_combine "$@" ;;
    *) t unknown_cmd "$cmd" >&2; echo >&2; usage >&2; exit 1 ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
